{
  "name": "teach-miniapp",
  "version": "1.0.0",
  "description": "教培微信小程序 — 老师+家长双角色",
  "scripts": {
    "dev:mp": "cross-env UNI_INPUT_DIR=. VITE_API_BASE_URL=http://localhost:3300/api uni -p mp-weixin",
    "dev:mp:prod": "cross-env UNI_INPUT_DIR=. VITE_API_BASE_URL=https://panpan.xpytt.com/api uni -p mp-weixin",
    "build:mp": "cross-env UNI_INPUT_DIR=. VITE_API_BASE_URL=https://panpan.xpytt.com/api uni build -p mp-weixin",
    "check:mp": "node scripts/mp-ci-upload.js --check",
    "upload:mp": "npm run build:mp && node scripts/mp-ci-upload.js",
    "dev:h5": "cross-env UNI_INPUT_DIR=. uni",
    "build:h5": "cross-env UNI_INPUT_DIR=. uni build"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4020920240930001",
    "@dcloudio/uni-h5": "3.0.0-4020920240930001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4020920240930001",
    "pinia": "^2.1.7",
    "sharp": "^0.35.1",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.0",
    "@dcloudio/uni-automator": "3.0.0-4020920240930001",
    "@dcloudio/uni-cli-shared": "3.0.0-4020920240930001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4020920240930001",
    "miniprogram-ci": "^2.1.31",
    "sass": "^1.69.0",
    "vite": "^5.4.0"
  },
  "main": "main.js",
